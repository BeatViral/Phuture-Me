{
  "name": "phuture-me",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite --config vite.dev.config.ts --host localhost",
    "build": "vinext build",
    "build:pages": "vite build --config vite.github.config.ts && node scripts/prepare-pages.mjs",
    "sync:pages-fallback": "npm run build:pages && node scripts/sync-pages-fallback.mjs",
    "start": "vinext start",
    "test": "npm run build && npm run test:unit",
    "test:unit": "node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern assets --ignore-pattern dist --ignore-pattern .next --ignore-pattern pages-dist"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
